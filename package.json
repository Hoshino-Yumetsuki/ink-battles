{
  "name": "ink-battles",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "yarn build:worker && wrangler dev --local --assets dist/client",
    "dev:client": "vite",
    "dev:worker": "yarn build:worker && wrangler dev --local",
    "build": "yarn build:client && yarn build:worker && yarn build:server",
    "build:client": "vite build",
    "build:worker": "node -e \"const fs=require('fs');fs.rmSync('dist/worker',{recursive:true,force:true});fs.rmSync('.wrangler/deploy/config.json',{force:true})\" && rolldown -c rolldown.config.js",
    "build:server": "node -e \"const fs=require('fs');fs.rmSync('dist/server',{recursive:true,force:true})\" && rolldown -c rolldown.server.config.js",
    "start": "node dist/server/index.js",
    "preview": "yarn build && wrangler dev --local",
    "deploy": "yarn build && wrangler deploy",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts",
    "lint": "biome check && biome lint",
    "lint-fix": "biome format --write && biome lint --write",
    "test": "vitest run --config vitest.config.ts"
  },
  "dependencies": {
    "@cap.js/server": "^4.0.5",
    "@cap.js/widget": "^0.1.53",
    "@fingerprintjs/fingerprintjs": "^5.2.0",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-icons": "^1.3.2",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@sinclair/typebox": "^0.34.49",
    "@valibot/to-json-schema": "^1.7.0",
    "@vitejs/plugin-react": "^6.0.2",
    "bcryptjs": "^3.0.3",
    "chardet": "^2.1.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "effect": "^3.21.2",
    "elysia": "^1.4.28",
    "file-type": "^22.0.1",
    "framer-motion": "^12.40.0",
    "geist": "^1.7.1",
    "iconv-lite": "^0.7.2",
    "jose": "^6.2.3",
    "lucide-react": "^1.17.0",
    "mammoth": "^1.12.0",
    "mermaid": "^11.15.0",
    "mongo-sanitize": "^1.1.0",
    "mongodb": "^7.2.0",
    "nodemailer": "^8.0.10",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-markdown": "^10.1.0",
    "remark": "^15.0.1",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "remark-stringify": "^11.0.0",
    "sonner": "^2.0.7",
    "sury": "^11.0.0-alpha.6",
    "tailwind-merge": "^3.6.0",
    "unified": "^11.0.5",
    "valibot": "^1.4.1",
    "vite": "^8.0.16",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.8",
    "xsai": "^0.5.0-beta.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@rolldown/plugin-node-polyfills": "^1.0.3",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/mongo-sanitize": "^1.0.3",
    "@types/mongodb": "^4.0.7",
    "@types/node": "^25.9.1",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "node-addon-api": "^8.8.0",
    "react-tabs": "^6.1.1",
    "rolldown": "^1.1.0",
    "shadcn": "^4.10.0",
    "tailwindcss": "^4.3.0",
    "tailwindcss-animate": "^1.0.7",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.3",
    "wrangler": "^4.96.0"
  },
  "packageManager": "yarn@4.14.1+sha512.64df448055b2d37ba269d7db535a469b8da93f8ef1140c25fd7a83c00a8fbaacb214ca0e02553b92a2c54cef78bb67d0b4817fab02001df0e24fac0faccc3b42",
  "type": "module"
}
