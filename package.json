{
  "name": "ink-battles",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "yarn build:worker && wrangler dev --local --assets dist/client",
    "dev:client": "vite",
    "dev:worker": "yarn build:worker && wrangler dev --local",
    "build": "yarn build:client && yarn build:worker && yarn build:server",
    "build:client": "vite build",
    "build:worker": "node -e \"const fs=require('fs');fs.rmSync('dist/worker',{recursive:true,force:true});fs.rmSync('.wrangler/deploy/config.json',{force:true})\" && rolldown -c rolldown.config.js",
    "build:server": "node -e \"const fs=require('fs');fs.rmSync('dist/server',{recursive:true,force:true})\" && rolldown -c rolldown.server.config.js",
    "start": "node dist/server/index.js",
    "preview": "yarn build && wrangler dev --local",
    "deploy": "yarn build && wrangler deploy",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts",
    "lint": "biome check && biome lint",
    "lint-fix": "biome format --write && biome lint --write",
    "test": "vitest run --config vitest.config.ts"
  },
  "dependencies": {
    "@cap.js/server": "^4.0.5",
    "@cap.js/widget": "^0.1.56",
    "@fingerprintjs/fingerprintjs": "^5.2.0",
    "@radix-ui/react-accordion": "^1.2.16",
    "@radix-ui/react-dialog": "^1.1.19",
    "@radix-ui/react-dropdown-menu": "^2.1.20",
    "@radix-ui/react-icons": "^1.3.2",
    "@radix-ui/react-label": "^2.1.11",
    "@radix-ui/react-progress": "^1.1.12",
    "@radix-ui/react-slider": "^1.4.3",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-switch": "^1.3.3",
    "@radix-ui/react-tabs": "^1.1.17",
    "@radix-ui/react-tooltip": "^1.2.12",
    "@sinclair/typebox": "^0.34.52",
    "@valibot/to-json-schema": "^1.7.1",
    "@vitejs/plugin-react": "^6.0.3",
    "bcryptjs": "^3.0.3",
    "chardet": "^2.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "effect": "^3.22.0",
    "elysia": "^1.4.29",
    "file-type": "^22.0.1",
    "framer-motion": "^12.42.2",
    "geist": "^1.7.2",
    "iconv-lite": "^0.7.3",
    "jose": "^6.2.3",
    "lucide-react": "^1.24.0",
    "mammoth": "^1.12.0",
    "mermaid": "^11.16.0",
    "mongo-sanitize": "^1.1.0",
    "mongodb": "^7.5.0",
    "nodemailer": "^9.0.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-markdown": "^10.1.0",
    "remark": "^15.0.1",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "remark-stringify": "^11.0.0",
    "sonner": "^2.0.7",
    "sury": "^11.0.0-alpha.10",
    "tailwind-merge": "^3.6.0",
    "unified": "^11.0.5",
    "valibot": "^1.4.2",
    "vite": "^8.1.4",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.10",
    "xsai": "^0.5.0-beta.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.4",
    "@rolldown/plugin-node-polyfills": "^1.0.3",
    "@tailwindcss/postcss": "^4.3.2",
    "@types/mongo-sanitize": "^1.0.3",
    "@types/mongodb": "^4.0.7",
    "@types/node": "^26.1.1",
    "@types/nodemailer": "^8.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "node-addon-api": "^8.9.0",
    "react-tabs": "^6.1.1",
    "rolldown": "^1.2.0",
    "shadcn": "^4.13.0",
    "tailwindcss": "^4.3.2",
    "tailwindcss-animate": "^1.0.7",
    "tw-animate-css": "^1.4.0",
    "typescript": "^7.0.2",
    "wrangler": "^4.111.0"
  },
  "packageManager": "yarn@4.17.1+sha512.ccbfabf7d7b6b32075088be9386fb9a2e00bb6887ef07fa56effabc890a56d53da1ccc4128d62db245fcbd3961b236d75335bdf7d5320ed6eafb7588b7ad4697",
  "type": "module"
}
